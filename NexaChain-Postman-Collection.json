{
  "info": {
    "_postman_id": "nexachain-ai-collection-v1",
    "name": "NexaChain AI — Investment & Referral Platform",
    "description": "Complete API collection for NexaChain AI MERN Stack platform.\n\nBase URL: http://localhost:5000/api\n\nAuth: After login/register, copy the token and set it in the collection variable `token`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); }",
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rahul Kumar\",\n  \"email\": \"rahul@example.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"Secure@123\",\n  \"referralCode\": \"\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          },
          "response": [{
            "name": "Success 201",
            "status": "Created",
            "code": 201,
            "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"64abc123def456\",\n    \"fullName\": \"Rahul Kumar\",\n    \"email\": \"rahul@example.com\",\n    \"referralCode\": \"AB12CD34\",\n    \"walletBalance\": 0\n  }\n}"
          }]
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); }",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"password\": \"Secure@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "response": [
            {
              "name": "Success 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"64abc123\",\n    \"fullName\": \"Rahul Kumar\",\n    \"email\": \"rahul@example.com\",\n    \"referralCode\": \"AB12CD34\",\n    \"walletBalance\": 0,\n    \"totalRoiEarned\": 0,\n    \"totalLevelIncomeEarned\": 0\n  }\n}"
            },
            {
              "name": "Invalid Credentials 401",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid email or password\"\n}"
            }
          ]
        },
        {
          "name": "Get Current User (Me)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has user', () => pm.expect(pm.response.json().user).to.be.an('object'));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
